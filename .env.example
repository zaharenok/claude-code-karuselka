# Tavily Research API
TAVILY_API_KEY=tvly-your_tavily_api_key_here

# Brave Search (alternative/complement)
BRAVE_API_KEY=your_brave_api_key_here

# Image Generation Provider
# Options: kie, openrouter, fal, local
IMAGE_GEN_PROVIDER=kie

# Image Generation API Keys
KIE_API_KEY=your_kie_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
FAL_API_KEY=your_fal_api_key_here

# Local Image Generation (if IMAGE_GEN_PROVIDER=local)
# Requires ollama serve running
LOCAL_MODEL=gemma2:latest

# Video Generation Provider
# Options: seedance, grok, fal
VIDEO_GEN_PROVIDER=seedance  # Seedance 1.5 Pro = cheapest on Kie.ai ($0.0175/s, 720p, no audio)

# Video Generation API Keys (only needed for grok/fal)
# GROK_API_KEY=your_grok_api_key_here  # Not used with seedance
GROK_VIDEO_API_KEY=your_grok_video_api_key_here

# Upload Storage
# Options: kie, s3, local
UPLOAD_STORAGE=kie

# Kie.ai Upload (if UPLOAD_STORAGE=kie)
# Uses same KIE_API_KEY as image generation

# S3 Upload (if UPLOAD_STORAGE=s3)
S3_BUCKET=your-bucket-name
S3_REGION=us-east-1
S3_ACCESS_KEY=your_s3_access_key
S3_SECRET_KEY=your_s3_secret_key

# Platform Publish
INSTAGRAM_MCP_ENDPOINT=http://localhost:3000
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token

META_ADS_ACCOUNT_ID=your_meta_ads_account_id
META_ADS_ACCESS_TOKEN=your_meta_ads_access_token

# Session Storage
SESSION_ROOT=~/.hermes/frameforge/sessions

# Logging
LOG_LEVEL=info